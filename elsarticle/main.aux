\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Comparison of time series classification methods. Feature counts are approximate and task-dependent. Taxonomy follows Middlehurst et al.\ \cite  {middlehurst2024bakeoff}. Interpretability is assessed on a three-level scale (High / Medium / Low) reflecting how readily extracted features can be understood by domain experts; this assessment is partially subjective. Methods marked with * are used as baselines in our experiments.}}{7}{table.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:feature_toolkits}{{1}{7}{Comparison of time series classification methods. Feature counts are approximate and task-dependent. Taxonomy follows Middlehurst et al.\ \cite {middlehurst2024bakeoff}. Interpretability is assessed on a three-level scale (High / Medium / Low) reflecting how readily extracted features can be understood by domain experts; this assessment is partially subjective. Methods marked with * are used as baselines in our experiments}{table.caption.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3}Methods}{8}{section.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}Overview}{8}{subsection.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces SublimeX methodology overview: The process begins with time series or spatial data, then applies multiple signal transformations to create parallel views of the data. Iterative feature discovery then: (1) proposes candidate feature parameters (channel, transform, segment boundaries), (2) extracts the segment from the transformed signal, (3) computes the mean over the segment, and (4) evaluates model performance via cross-validation. The best feature is appended to the feature set and the procedure repeats until adding a new feature no longer improves performance.}}{8}{figure.caption.2}\protected@file@percent }
\newlabel{fig:sublime_methodology}{{1}{8}{SublimeX methodology overview: The process begins with time series or spatial data, then applies multiple signal transformations to create parallel views of the data. Iterative feature discovery then: (1) proposes candidate feature parameters (channel, transform, segment boundaries), (2) extracts the segment from the transformed signal, (3) computes the mean over the segment, and (4) evaluates model performance via cross-validation. The best feature is appended to the feature set and the procedure repeats until adding a new feature no longer improves performance}{figure.caption.2}{}}
