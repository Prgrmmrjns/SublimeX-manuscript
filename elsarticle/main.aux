\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Domain-Specific Pattern Interpretation}{16}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Domain-specific pattern interpretation comparing REMC (left column) and MITBIH (right column) datasets. Each column illustrates the pattern extraction mechanism through three panels: (A) Biological Context showing average class profiles with the pattern search region highlighted (gray background), (B) Pattern Matching Mechanism in the transformed signal space with the learned B-spline pattern (green) overlaid at optimal positions and error regions (hatched) visualized, and (C) Feature Discrimination via RMSE distributions demonstrating class separation. REMC: H3K4me3 histone mark pattern (raw transform, width 98 bins) for gene expression prediction in cell line E003. MITBIH: ECG beat pattern (z-score transform, width 47 samples) for arrhythmia classification. The visualization demonstrates how patX automatically selects discriminative transformations and discovers interpretable patterns aligned with domain knowledge.}}{18}{figure.caption.6}\protected@file@percent }
\newlabel{fig:domain_pattern_interpretation}{{2}{18}{Domain-specific pattern interpretation comparing REMC (left column) and MITBIH (right column) datasets. Each column illustrates the pattern extraction mechanism through three panels: (A) Biological Context showing average class profiles with the pattern search region highlighted (gray background), (B) Pattern Matching Mechanism in the transformed signal space with the learned B-spline pattern (green) overlaid at optimal positions and error regions (hatched) visualized, and (C) Feature Discrimination via RMSE distributions demonstrating class separation. REMC: H3K4me3 histone mark pattern (raw transform, width 98 bins) for gene expression prediction in cell line E003. MITBIH: ECG beat pattern (z-score transform, width 47 samples) for arrhythmia classification. The visualization demonstrates how patX automatically selects discriminative transformations and discovers interpretable patterns aligned with domain knowledge}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Clinical Decision Making with patX: ARDS Prediction in MIMIC-IV}{18}{subsection.4.4}\protected@file@percent }
\citation{tonekaboni2019clinicians,caruana2015intelligible}
\citation{ye2009shapelets,hills2014shapelet,syed2010motif,mueen2014motif}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Clinician-facing SHAP summary for ARDS prediction using patX patterns from MIMIC-IV. A LightGBM model trained on nine pattern features achieves 82.5\% test accuracy after binarizing labels to ARDS vs.\ no ARDS. The top three patterns by mean absolute SHAP value are shown with their learned shape, feature mismatch distribution (RMSE), and SHAP contribution distribution, enabling direct clinical inspection of the evidence.}}{20}{figure.caption.7}\protected@file@percent }
\newlabel{fig:mimic_shap_clinical}{{3}{20}{Clinician-facing SHAP summary for ARDS prediction using patX patterns from MIMIC-IV. A LightGBM model trained on nine pattern features achieves 82.5\% test accuracy after binarizing labels to ARDS vs.\ no ARDS. The top three patterns by mean absolute SHAP value are shown with their learned shape, feature mismatch distribution (RMSE), and SHAP contribution distribution, enabling direct clinical inspection of the evidence}{figure.caption.7}{}}
