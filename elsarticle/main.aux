\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.5.2}AZT1D: Glucose Forecasting from Continuous Monitoring Data}{21}{subsubsection.4.5.2}\protected@file@percent }
\citation{khamesian2025azt1d}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Domain interpretation via SHAP analysis for two biomedical tasks. \textbf  {Top row}: REMC gene expression prediction (cell line E003, fold~1). \textbf  {(A)}~Mean H3K4me3 signal within the SublimeX-extracted segment (bins~65--96, near the TSS) for highly expressed (red) and lowly expressed (blue) genes. \textbf  {(B)}~Class-conditional density of the extracted H3K4me3 feature values. \textbf  {(C)}~SHAP beeswarm plot for all 12~features. \textbf  {Bottom row}: AZT1D glucose forecasting (fold~1). \textbf  {(D)}~Mean CGM signal within the top feature segment ($-$40 to 0~min) for samples with rising (red) vs.\ falling (blue) glucose 60~minutes ahead. \textbf  {(E)}~Distribution of the top CGM feature for rising vs.\ falling glucose groups. \textbf  {(F)}~SHAP beeswarm plot for all 16~features. In all beeswarm plots, each dot is one test sample; color indicates the feature value (red~=~high, blue~=~low) and horizontal position shows the SHAP contribution.}}{23}{figure.caption.8}\protected@file@percent }
\newlabel{fig:domain_interpretation}{{4}{23}{Domain interpretation via SHAP analysis for two biomedical tasks. \textbf {Top row}: REMC gene expression prediction (cell line E003, fold~1). \textbf {(A)}~Mean H3K4me3 signal within the SublimeX-extracted segment (bins~65--96, near the TSS) for highly expressed (red) and lowly expressed (blue) genes. \textbf {(B)}~Class-conditional density of the extracted H3K4me3 feature values. \textbf {(C)}~SHAP beeswarm plot for all 12~features. \textbf {Bottom row}: AZT1D glucose forecasting (fold~1). \textbf {(D)}~Mean CGM signal within the top feature segment ($-$40 to 0~min) for samples with rising (red) vs.\ falling (blue) glucose 60~minutes ahead. \textbf {(E)}~Distribution of the top CGM feature for rising vs.\ falling glucose groups. \textbf {(F)}~SHAP beeswarm plot for all 16~features. In all beeswarm plots, each dot is one test sample; color indicates the feature value (red~=~high, blue~=~low) and horizontal position shows the SHAP contribution}{figure.caption.8}{}}
\citation{karlic2010histone,howe2017h3k4me3}
