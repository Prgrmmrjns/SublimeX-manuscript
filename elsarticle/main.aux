\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Transform Composition and Pattern Stability}{14}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Transform composition and pattern stability. (A)~Proportion of \emph  {all} extracted features using each signal transformation per dataset. (B)~Segment position of the \emph  {first} (highest-ranked) extracted feature across cross-validation folds. Horizontal bars show the mean segment position; error bars indicate positional variability across folds. Labels show T (transform consistency) and C (channel consistency for multivariate datasets) as the fraction of folds selecting the same transform/channel for that first feature.}}{14}{figure.caption.5}\protected@file@percent }
\newlabel{fig:performance_analysis}{{2}{14}{Transform composition and pattern stability. (A)~Proportion of \emph {all} extracted features using each signal transformation per dataset. (B)~Segment position of the \emph {first} (highest-ranked) extracted feature across cross-validation folds. Horizontal bars show the mean segment position; error bars indicate positional variability across folds. Labels show T (transform consistency) and C (channel consistency for multivariate datasets) as the fraction of folds selecting the same transform/channel for that first feature}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Incremental Feature Analysis}{15}{subsection.4.3}\protected@file@percent }
\newlabel{sec:feature_analysis}{{4.3}{15}{Incremental Feature Analysis}{subsection.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Incremental feature analysis showing train, validation, and test performance as features are added. The model is trained on the optimization-train subset (the same data used during feature search) and evaluated on all three splits. Solid lines show mean performance across folds; shaded areas indicate $\pm $1 standard deviation. Note that across folds different amounts of features are extracted and thus standard deviation may not be available for all incremental evaluations.}}{16}{figure.caption.6}\protected@file@percent }
\newlabel{fig:incremental_features}{{3}{16}{Incremental feature analysis showing train, validation, and test performance as features are added. The model is trained on the optimization-train subset (the same data used during feature search) and evaluated on all three splits. Solid lines show mean performance across folds; shaded areas indicate $\pm $1 standard deviation. Note that across folds different amounts of features are extracted and thus standard deviation may not be available for all incremental evaluations}{figure.caption.6}{}}
